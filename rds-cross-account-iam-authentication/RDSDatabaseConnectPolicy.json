{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Effect": "Allow",
            "Action": [
                "rds-db:connect"
            ],
            "Resource": [
                "arn:aws:rds-db:us-west-2:<DB_ACCOUNT_ID>:dbuser:<DB_RESOURCE_ID>/admin"
            ]
        }
    ]
}